# Arda Infrastructure Secrets
# Copy this file to .env and fill in values

# GitHub PAT for arda-infra repo (used by CI/CD deploy step)
INFRA_REPO_PAT=

# APISIX Gateway
APISIX_API_KEY=

# Zitadel
ZITADEL_ADMIN_PASSWORD=
ZITADEL_PG_DSN=postgresql://zitadel:CHANGE_ME@zitadel-postgresql:5432/zitadel?sslmode=disable
ZITADEL_PG_USER=zitadel
ZITADEL_PG_PASSWORD=
